<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_document_list" model="ir.ui.view">
        <field name="name">hr_mgmt.employee_document.list</field>
        <field name="model">hr_mgmt.employee_document</field>
        <field name="arch" type="xml">
            <list string="Employee Documents">
                <field name="employee_id"/>
                <field name="name"/>
                <field name="document_type"/>
                <field name="expiry_date"/>
            </list>
        </field>
    </record>

    <record id="view_employee_document_form" model="ir.ui.view">
        <field name="name">hr_mgmt.employee_document.form</field>
        <field name="model">hr_mgmt.employee_document</field>
        <field name="arch" type="xml">
            <form string="Employee Document">
                <sheet>
                    <group>
                        <field name="employee_id"/>
                        <field name="name"/>
                        <field name="document_type"/>
                        <field name="file" filename="filename"/>
                        <field name="filename" invisible="1"/>
                        <field name="expiry_date"/>
                    </group>
                    <field name="notes"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_employee_document" model="ir.actions.act_window">
        <field name="name">Employee Documents</field>
        <field name="res_model">hr_mgmt.employee_document</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_disciplinary_record_list" model="ir.ui.view">
        <field name="name">hr_mgmt.disciplinary_record.list</field>
        <field name="model">hr_mgmt.disciplinary_record</field>
        <field name="arch" type="xml">
            <list string="Disciplinary Records">
                <field name="employee_id"/>
                <field name="date"/>
                <field name="incident_type"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_disciplinary_record_form" model="ir.ui.view">
        <field name="name">hr_mgmt.disciplinary_record.form</field>
        <field name="model">hr_mgmt.disciplinary_record</field>
        <field name="arch" type="xml">
            <form string="Disciplinary Record">
                <header>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="employee_id"/>
                        <field name="date"/>
                        <field name="incident_type"/>
                        <field name="action_taken"/>
                    </group>
                    <field name="description"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_disciplinary_record" model="ir.actions.act_window">
        <field name="name">Disciplinary Records</field>
        <field name="res_model">hr_mgmt.disciplinary_record</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
