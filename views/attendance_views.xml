<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_attendance_list" model="ir.ui.view">
        <field name="name">hr_mgmt.attendance.list</field>
        <field name="model">hr_mgmt.attendance</field>
        <field name="arch" type="xml">
            <list string="Attendance">
                <field name="employee_id"/>
                <field name="date"/>
                <field name="check_in"/>
                <field name="check_out"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="view_attendance_form" model="ir.ui.view">
        <field name="name">hr_mgmt.attendance.form</field>
        <field name="model">hr_mgmt.attendance</field>
        <field name="arch" type="xml">
            <form string="Attendance">
                <sheet>
                    <group>
                        <field name="employee_id"/>
                        <field name="date"/>
                        <field name="check_in"/>
                        <field name="check_out"/>
                        <field name="status"/>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_attendance" model="ir.actions.act_window">
        <field name="name">Attendance</field>
        <field name="res_model">hr_mgmt.attendance</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
