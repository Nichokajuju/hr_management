<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_designation_list" model="ir.ui.view">
        <field name="name">hr_mgmt.designation.list</field>
        <field name="model">hr_mgmt.designation</field>
        <field name="arch" type="xml">
            <list string="Designations">
                <field name="name"/>
                <field name="department_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_designation_form" model="ir.ui.view">
        <field name="name">hr_mgmt.designation.form</field>
        <field name="model">hr_mgmt.designation</field>
        <field name="arch" type="xml">
            <form string="Designation">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="department_id"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_designation" model="ir.actions.act_window">
        <field name="name">Designations</field>
        <field name="res_model">hr_mgmt.designation</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
