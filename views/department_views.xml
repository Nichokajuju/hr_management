<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_department_list" model="ir.ui.view">
        <field name="name">hr_mgmt.department.list</field>
        <field name="model">hr_mgmt.department</field>
        <field name="arch" type="xml">
            <list string="Departments">
                <field name="name"/>
                <field name="code"/>
                <field name="manager_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_department_form" model="ir.ui.view">
        <field name="name">hr_mgmt.department.form</field>
        <field name="model">hr_mgmt.department</field>
        <field name="arch" type="xml">
            <form string="Department">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="manager_id"/>
                        <field name="parent_id"/>
                        <field name="active"/>
                    </group>
                    <field name="notes"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_department" model="ir.actions.act_window">
        <field name="name">Departments</field>
        <field name="res_model">hr_mgmt.department</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
