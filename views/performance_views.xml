<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_goal_list" model="ir.ui.view">
        <field name="name">hr_mgmt.goal.list</field>
        <field name="model">hr_mgmt.goal</field>
        <field name="arch" type="xml">
            <list string="Goals">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="deadline"/>
                <field name="progress"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_goal_form" model="ir.ui.view">
        <field name="name">hr_mgmt.goal.form</field>
        <field name="model">hr_mgmt.goal</field>
        <field name="arch" type="xml">
            <form string="Goal">
                <header>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="employee_id"/>
                        <field name="deadline"/>
                        <field name="progress"/>
                    </group>
                    <field name="description"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_goal" model="ir.actions.act_window">
        <field name="name">Goals</field>
        <field name="res_model">hr_mgmt.goal</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_performance_review_list" model="ir.ui.view">
        <field name="name">hr_mgmt.performance_review.list</field>
        <field name="model">hr_mgmt.performance_review</field>
        <field name="arch" type="xml">
            <list string="Performance Reviews">
                <field name="employee_id"/>
                <field name="reviewer_id"/>
                <field name="review_date"/>
                <field name="rating"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_performance_review_form" model="ir.ui.view">
        <field name="name">hr_mgmt.performance_review.form</field>
        <field name="model">hr_mgmt.performance_review</field>
        <field name="arch" type="xml">
            <form string="Performance Review">
                <header>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="employee_id"/>
                        <field name="reviewer_id"/>
                        <field name="review_date"/>
                        <field name="period"/>
                        <field name="rating"/>
                    </group>
                    <field name="comments"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_performance_review" model="ir.actions.act_window">
        <field name="name">Performance Reviews</field>
        <field name="res_model">hr_mgmt.performance_review</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
