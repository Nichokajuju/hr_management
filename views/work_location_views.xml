<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_work_location_list" model="ir.ui.view">
        <field name="name">hr_mgmt.work_location.list</field>
        <field name="model">hr_mgmt.work_location</field>
        <field name="arch" type="xml">
            <list string="Work Locations">
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_work_location_form" model="ir.ui.view">
        <field name="name">hr_mgmt.work_location.form</field>
        <field name="model">hr_mgmt.work_location</field>
        <field name="arch" type="xml">
            <form string="Work Location">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="address"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_work_location" model="ir.actions.act_window">
        <field name="name">Work Locations</field>
        <field name="res_model">hr_mgmt.work_location</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
