<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_leave_type_list" model="ir.ui.view">
        <field name="name">hr_mgmt.leave_type.list</field>
        <field name="model">hr_mgmt.leave_type</field>
        <field name="arch" type="xml">
            <list string="Leave Types">
                <field name="name"/>
                <field name="max_days"/>
            </list>
        </field>
    </record>

    <record id="view_leave_type_form" model="ir.ui.view">
        <field name="name">hr_mgmt.leave_type.form</field>
        <field name="model">hr_mgmt.leave_type</field>
        <field name="arch" type="xml">
            <form string="Leave Type">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="max_days"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_leave_type" model="ir.actions.act_window">
        <field name="name">Leave Types</field>
        <field name="res_model">hr_mgmt.leave_type</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_leave_request_list" model="ir.ui.view">
        <field name="name">hr_mgmt.leave_request.list</field>
        <field name="model">hr_mgmt.leave_request</field>
        <field name="arch" type="xml">
            <list string="Leave Requests">
                <field name="employee_id"/>
                <field name="leave_type_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_leave_request_form" model="ir.ui.view">
        <field name="name">hr_mgmt.leave_request.form</field>
        <field name="model">hr_mgmt.leave_request</field>
        <field name="arch" type="xml">
            <form string="Leave Request">
                <header>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="employee_id"/>
                        <field name="leave_type_id"/>
                        <field name="date_from"/>
                        <field name="date_to"/>
                        <field name="reason"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_leave_request" model="ir.actions.act_window">
        <field name="name">Leave Requests</field>
        <field name="res_model">hr_mgmt.leave_request</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
