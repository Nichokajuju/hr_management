<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_list" model="ir.ui.view">
        <field name="name">hr_mgmt.employee.list</field>
        <field name="model">hr_mgmt.employee</field>
        <field name="arch" type="xml">
            <list string="Employees">
                <field name="employee_id"/>
                <field name="name"/>
                <field name="department_id"/>
                <field name="designation_id"/>
                <field name="phone"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_employee_form" model="ir.ui.view">
        <field name="name">hr_mgmt.employee.form</field>
        <field name="model">hr_mgmt.employee</field>
        <field name="arch" type="xml">
            <form string="Employee">
                <sheet>
                    <field name="photo" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                        <h2><field name="designation_id"/></h2>
                    </div>
                    <group>
                        <group string="Personal Info">
                            <field name="employee_id"/>
                            <field name="gender"/>
                            <field name="date_of_birth"/>
                            <field name="age"/>
                            <field name="national_id"/>
                            <field name="phone"/>
                            <field name="email"/>
                            <field name="address"/>
                        </group>
                        <group string="Work Info">
                            <field name="department_id"/>
                            <field name="designation_id"/>
                            <field name="work_location_id"/>
                            <field name="manager_id"/>
                            <field name="state"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Employment Details">
                            <field name="employment_detail_ids">
                                <list editable="bottom">
                                    <field name="contract_type"/>
                                    <field name="date_joined"/>
                                    <field name="end_date"/>
                                    <field name="salary"/>
                                </list>
                            </field>
                        </page>
                        <page string="Documents">
                            <field name="document_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="document_type"/>
                                    <field name="expiry_date"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_employee" model="ir.actions.act_window">
        <field name="name">Employees</field>
        <field name="res_model">hr_mgmt.employee</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
