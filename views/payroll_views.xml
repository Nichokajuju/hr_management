<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_salary_structure_list" model="ir.ui.view">
        <field name="name">hr_mgmt.salary_structure.list</field>
        <field name="model">hr_mgmt.salary_structure</field>
        <field name="arch" type="xml">
            <list string="Salary Structures">
                <field name="name"/>
                <field name="basic_salary"/>
            </list>
        </field>
    </record>

    <record id="view_salary_structure_form" model="ir.ui.view">
        <field name="name">hr_mgmt.salary_structure.form</field>
        <field name="model">hr_mgmt.salary_structure</field>
        <field name="arch" type="xml">
            <form string="Salary Structure">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="basic_salary"/>
                        <field name="housing_allowance"/>
                        <field name="transport_allowance"/>
                        <field name="other_allowances"/>
                        <field name="tax_deduction"/>
                        <field name="other_deductions"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_salary_structure" model="ir.actions.act_window">
        <field name="name">Salary Structures</field>
        <field name="res_model">hr_mgmt.salary_structure</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_payslip_list" model="ir.ui.view">
        <field name="name">hr_mgmt.payslip.list</field>
        <field name="model">hr_mgmt.payslip</field>
        <field name="arch" type="xml">
            <list string="Pay Slips">
                <field name="employee_id"/>
                <field name="month"/>
                <field name="year"/>
                <field name="gross_salary"/>
                <field name="net_salary"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_payslip_form" model="ir.ui.view">
        <field name="name">hr_mgmt.payslip.form</field>
        <field name="model">hr_mgmt.payslip</field>
        <field name="arch" type="xml">
            <form string="Pay Slip">
                <header>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="employee_id"/>
                        <field name="salary_structure_id"/>
                        <field name="month"/>
                        <field name="year"/>
                        <field name="gross_salary"/>
                        <field name="total_deductions"/>
                        <field name="net_salary"/>
                    </group>
                    <field name="notes"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_payslip" model="ir.actions.act_window">
        <field name="name">Pay Slips</field>
        <field name="res_model">hr_mgmt.payslip</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
